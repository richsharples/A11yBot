# Anthropic API key — required for AI drafting.
# Get one at https://console.anthropic.com → API Keys
# Can also be entered interactively in the setup wizard (stored in session memory only).
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for AI drafting (optional — defaults to claude-sonnet-4-6)
# VPAT_MODEL=claude-sonnet-4-6

# Port for the dev/prod server (optional — defaults to 5173)
# VPAT_PORT=5173

# Log level for pino (optional — defaults to "info")
# LOG_LEVEL=debug
